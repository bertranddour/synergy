# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-min-32-characters-long

# Magic link token signing secret — generate with: openssl rand -hex 32
MAGIC_LINK_SECRET=your-magic-link-secret-min-32-characters-long

# Cloudflare account ID — find in Cloudflare dashboard → Workers & Pages
CF_ACCOUNT_ID=your-cloudflare-account-id

# AI Gateway ID — create at Cloudflare dashboard → AI → AI Gateway
AI_GATEWAY_ID=your-ai-gateway-id

# AI Gateway authentication token — generate in AI Gateway settings
# NOTE: The Anthropic API key is stored on the AI Gateway dashboard under Provider Keys.
# This token authenticates the Worker to the gateway (BYOK pattern).
AI_GATEWAY_TOKEN=your-ai-gateway-token

# Resend API Key
RESEND_API_KEY=your-resend-api-key

# Environment
ENVIRONMENT=development
