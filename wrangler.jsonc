{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "synergy-api",
  "main": "packages/api/src/index.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,

  // Custom domain
  "routes": [
    {
      "pattern": "synergy.7flows.com",
      "custom_domain": true
    }
  ],

  // Workers Static Assets — serves React SPA + API from one Worker
  "assets": {
    "directory": "./packages/web/dist",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"],
    "not_found_handling": "single-page-application"
  },

  // D1 Database
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "synergy-db",
      "database_id": "2c87522d-517b-4e9d-bd90-88772cd89c07",
      "migrations_dir": "packages/api/src/db/migrations"
    }
  ],

  // KV Namespace (sessions, cache)
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "357e1e3cf9b54ebbab931a887cd0d22a"
    }
  ],

  // R2 Bucket (exports, uploads)
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "synergy-uploads"
    }
  ],

  // Queues (background jobs)
  "queues": {
    "producers": [
      {
        "binding": "QUEUE",
        "queue": "synergy-background"
      }
    ],
    "consumers": [
      {
        "queue": "synergy-background",
        "max_batch_size": 10,
        "max_batch_timeout": 30
      }
    ]
  },

  // Durable Objects (Alicia Agent)
  "durable_objects": {
    "bindings": [
      {
        "name": "ALICIA",
        "class_name": "AliciaAgent"
      }
    ]
  },

  // Durable Object migrations
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["AliciaAgent"]
    }
  ],

  // Cron Triggers (proactive observations — hourly)
  "triggers": {
    "crons": ["0 * * * *"]
  },

  // Workers AI
  "ai": {
    "binding": "AI"
  },

  // Environment variables
  "vars": {
    "ENVIRONMENT": "production"
  }

  // Secrets (set via `wrangler secret bulk .dev.vars`):
  // JWT_SECRET, MAGIC_LINK_SECRET, AI_GATEWAY_TOKEN
  // CF_ACCOUNT_ID, AI_GATEWAY_ID
  // Note: Anthropic API key is on AI Gateway dashboard (BYOK), NOT a Worker secret
}
